{%- macro render_options(opt_group) -%}

{% if opt_group is defined and opt_group is not none %}
{% for opt in opt_group %}
{% if opt_group[opt] is defined and opt_group[opt] is not none %}
{% if opt_group[opt] is string %}
{{ opt }}={{ opt_group[opt] }}
{% elif opt_group[opt] is sequence %}
{% for elem in opt_group[opt] %}
{{ opt }}="{{ elem }}"
{% endfor %}
{% else %}
{% endif %}
{% endif %}
{% endfor %}
{% endif %}

{%- endmacro -%}

